# ── Gemini (Built-in LLM) ──────────────────────────
GEMINI_API_KEY=

# ── GitHub PAT (Plugin Downloads from Private Repos) ─
GITHUB_PAT=

# ── Development Mode (bypasses license checks) ─────
DEV_MODE=false

# ── Legacy LLM Adapter (Phase 5 で MCP 移行予定) ───
LLM_ADAPTER=openai_compat
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=none
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
SKILLS_PATH=./skills/SKILLS.md

# OpenVINO Settings (Use when LLM_ADAPTER=openvino_genai)
OPENVINO_MODEL_PATH=./models/llm
OPENVINO_DEVICE=AUTO
OPENVINO_PERFORMANCE_MODE=LATENCY
